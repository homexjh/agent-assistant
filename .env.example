# AIAgent 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ==================== LLM API 配置 ====================
# API Key (必填)
# 支持 OpenAI、Moonshot(Kimi)、或其他兼容 OpenAI API 格式的服务商
OPENAI_API_KEY=sk-xxx

# API Base URL (可选，默认使用 Moonshot)
# OpenAI: https://api.openai.com/v1
# Moonshot(Kimi): https://api.moonshot.cn/v1
# 阿里云(通义千问): https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.moonshot.cn/v1

# 模型选择 (可选，默认 kimi-k2.5)
# Moonshot 模型: kimi-k2.5, kimi-k2-0711-preview, moonshot-v1-8k
# OpenAI 模型: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# 通义千问模型: qwen3-max-2026-01-23, qwen3.5-plus, qwen3-coder-plus
MODEL=kimi-k2.5

# ==================== Web UI 默认配置 ====================
# 以下配置仅影响 Web 界面的默认值
# 用户可以在浏览器设置中覆盖这些值

# 默认 Provider (kimi/qwen)
DEFAULT_PROVIDER=kimi

# 默认模型
DEFAULT_MODEL=kimi-k2.5

# ==================== 可选配置 ====================
# 自定义端口 (默认 8765)
# PORT=8765

# 日志级别 (debug/info/warn/error)
# LOG_LEVEL=info

# 工作区路径
# WORKSPACE_DIR=./workspace
